# Default behavior: text files auto-converted, normalized to LF in repo
* text=auto eol=lf

# Source files — force LF
*.md      text eol=lf
*.py      text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.dart    text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sh      text eol=lf
*.sql     text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.toml    text eol=lf

# Windows-specific scripts — keep CRLF
*.ps1     text eol=crlf
*.bat     text eol=crlf
*.cmd     text eol=crlf

# Binary — no conversion
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.zip     binary
*.gz      binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.mp4     binary
*.mp3     binary
*.db      binary
*.sqlite  binary
*.sqlite3 binary
